        <!-- ===== EXTERNAL ACTORS (People) ===== -->
        <mxCell id="person_doctor" value="&lt;b&gt;Врач&lt;/b&gt;&lt;br&gt;[Пользователь]&lt;br&gt;&lt;br&gt;Проводит осмотры,&lt;br&gt;назначает лечение,&lt;br&gt;использует ИИ-диагностику" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#08427B;fontColor=#ffffff;strokeColor=#073B6F;arcSize=50;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
