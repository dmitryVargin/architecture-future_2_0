        <mxCell id="person_operator" value="&lt;b&gt;Оператор клиники&lt;/b&gt;&lt;br&gt;[Пользователь]&lt;br&gt;&lt;br&gt;Регистрирует пациентов,&lt;br&gt;управляет расписанием" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#08427B;fontColor=#ffffff;strokeColor=#073B6F;arcSize=50;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="1">
